                    {%endif%}
                } else {
                    let prop_lock = property_pointer.read().await;
                    {%if prop.arg_list | length == 1 %}
                    {{prop_name | UpperCamelCase}}Property { 
                        {{prop.arg_list[0].name}}: (*prop_lock).clone(),
                    }
                    {%else%}
                    (*prop_lock).clone()
                    {%endif%}
