constexpr const char {{stinger.cpp.server_class_name}}::NAME[];
constexpr const char {{stinger.cpp.server_class_name}}::INTERFACE_VERSION[];

{{stinger.cpp.server_class_name}}::{{stinger.cpp.server_class_name}}(std::shared_ptr<stinger::utils::IConnection> broker, const std::string& instanceId{%for topic_param in config.topics.params %}, const std::string& {{topic_param|lowerCamelCase}}{%endfor%})
        : _broker(broker), _instanceId(instanceId), _advertisementThreadRunning(false){%-for topic_param in config.topics.params %}, _{{topic_param | lowerCamelCase}}TopicParam( {{topic_param|lowerCamelCase}} ){%endfor%}
        
{
    _brokerMessageCallbackHandle = _broker->AddMessageCallback([this](
            const stinger::mqtt::Message& msg)
    {
        _receiveMessage(msg);
    });

    std::map<std::string, std::string> topicArgs;
    topicArgs["service_id"] = _instanceId;
    topicArgs["interface_name"] = NAME;
    topicArgs["client_id"] = _broker->GetClientId();
    {%-for topic_param in config.topics.params %}
    topicArgs["{{topic_param}}"] = _{{topic_param|lowerCamelCase}}TopicParam;
    {%-endfor%}

    {%for method in stinger.methods.values()%}
    _{{method.name | camelCase}}MethodSubscriptionId = _broker->Subscribe(stinger::utils::format("{{method.request_topic()}}", topicArgs), 2);
    {%-endfor%}
    {%for prop_name, prop in stinger.properties.items()%}
    _{{prop_name | lowerCamelCase}}PropertySubscriptionId = _broker->Subscribe(stinger::utils::format("{{prop.update_topic()}}", topicArgs), 1);
    {%-endfor%}

    // Start the service advertisement thread
    _advertisementThreadRunning = true;
    _advertisementThread = std::thread(&{{stinger.cpp.server_class_name}}::_advertisementThreadLoop, this);
}

{{stinger.cpp.server_class_name}}::~{{stinger.cpp.server_class_name}}()
{
    // Unregister the message callback from the broker.
    if (_broker && _brokerMessageCallbackHandle != 0)
    {
        _broker->RemoveMessageCallback(_brokerMessageCallbackHandle);
        _brokerMessageCallbackHandle = 0;
    }

    // Stop the advertisement thread
    _advertisementThreadRunning = false;
    if (_advertisementThread.joinable())
    {
        _advertisementThread.join();
    }

    std::map<std::string, std::string> topicArgs;
    topicArgs["service_id"] = _instanceId;
    topicArgs["interface_name"] = NAME;
    topicArgs["client_id"] = _broker->GetClientId();
    {%- for topic_param in config.topics.params %}
    topicArgs["{{topic_param}}"] = _{{topic_param|lowerCamelCase}}TopicParam;
    {%-endfor%}

    std::string topic = stinger::utils::format("{{stinger.interface_info_topic()}}", topicArgs);
    auto msg = stinger::mqtt::Message::ServiceOffline(topic);
    _broker->Publish(msg);

    {%for method in stinger.methods.values()%}
    _broker->Unsubscribe(stinger::utils::format("{{method.request_topic()}}", topicArgs));
    {%-endfor%}
    {%for prop_name, prop in stinger.properties.items()%}
    _broker->Unsubscribe(stinger::utils::format("{{ prop.update_topic() }}", topicArgs));
    {%-endfor%}
}

void {{stinger.cpp.server_class_name}}::_receiveMessage(const stinger::mqtt::Message& msg)
{
    const int noSubId = -1;
    int subscriptionId = msg.properties.subscriptionId.value_or(noSubId);
    {%for method_name, method in stinger.methods.items()%}
    {%if not loop.first%}else {%endif%}if (subscriptionId == _{{method_name | camelCase}}MethodSubscriptionId)
    {
        _broker->Log(LOG_INFO,"Message to `%s` matched as {{method_name}} method request.", msg.topic.c_str());
        rapidjson::Document doc;
        try {
            if (_{{method_name | camelCase}}Handler)
            {
                rapidjson::ParseResult ok = doc.Parse(msg.payload.c_str());
                if (!ok)
                {
                    //Log("Could not JSON parse {{sig_name}} signal payload.");
                    throw std::runtime_error(rapidjson::GetParseError_En(ok.Code()));
                }

                if (!doc.IsObject()) {
                    throw std::runtime_error("Received payload is not an object");
                }

                _call{{method_name | UpperCamelCase}}Handler(msg.topic, doc, msg.properties.correlationData, msg.properties.responseTopic);
            }
        }
        catch (const std::exception&)
        {
            // We couldn't find an integer out of the string in the topic name,
            // so we are dropping the message completely. 
            // TODO: Log this failure
        }
    }
    {%endfor%}
    {%for prop_name, prop in stinger.properties.items()%}
    {%if not loop.first%}else {%endif%}if (subscriptionId == _{{prop_name | lowerCamelCase}}PropertySubscriptionId)
    {
        _broker->Log(LOG_INFO,"Message to `%s` matched as {{prop_name}} property update.", msg.topic.c_str());
        _receive{{prop_name | UpperCamelCase}}PropertyUpdate(msg);
    }
    {%endfor%}
}

{%for sig_name, sig in stinger.signals.items()%}
std::future<bool> {{stinger.cpp.server_class_name}}::emit{{sig_name | UpperCamelCase}}Signal({%for arg in sig.arg_list%}{{arg.cpp_func_param_type}} {{arg.name|lowerCamelCase}}{%if not loop.last%}, {%endif%}{%endfor%})
{
    rapidjson::Document doc;
    doc.SetObject();

    {%-for arg in sig.arg_list%}
    {{ser.addToValue('doc', arg, 'doc.GetAllocator()') | indent}}
    {%-endfor%}
    rapidjson::StringBuffer buf;
    rapidjson::Writer<rapidjson::StringBuffer> writer(buf);
    doc.Accept(writer);

    std::map<std::string, std::string> topicArgs;
    topicArgs["service_id"] = _instanceId;
    topicArgs["interface_name"] = NAME;
    topicArgs["client_id"] = _broker->GetClientId();
    topicArgs["signal_name"] = "{{sig_name}}";
    {%-for topic_param in config.topics.params %}
    topicArgs["{{topic_param}}"] = _{{topic_param|lowerCamelCase}}TopicParam;
    {%-endfor%}
    auto topic = stinger::utils::format("{{sig.topic()}}", topicArgs);
    auto msg = stinger::mqtt::Message::Signal(topic, buf.GetString());
    return _broker->Publish(msg);
}
