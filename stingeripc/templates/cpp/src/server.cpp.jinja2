{%for method_name, method in stinger.methods.items()%}
void {{stinger.cpp.server_class_name}}::_call{{method_name | UpperCamelCase}}Handler(
        const std::string& topic, 
        const rapidjson::Document& doc, 
        const std::optional<std::vector<std::byte>>& optCorrelationData,
        const std::optional<std::string>& optResponseTopic) const
{
    _broker->Log(LOG_INFO, "Handling call to {{method_name}}");
    if (!_{{method_name | camelCase}}Handler) {
        // TODO: publish an error response because we don't have a method handler.
        return;
    }
    {%if method.arg_list | length > 0 %}
    auto requestArgs = {{method_name | UpperCamelCase}}RequestArguments::FromRapidJsonObject(doc);
    {%endif%}
    {%if method.return_arg_list | length == 0 %}
    // Method doesn't have any return values.
    _{{method_name | camelCase}}Handler({%for arg in method.arg_list%}requestArgs.{{arg.name|lowerCamelCase}}{%if not loop.last%}, {%endif%}{%endfor%});
    auto returnValues = {{method_name | UpperCamelCase}}ReturnValues();
    {%elif method.return_arg_list | length == 1%}
    // Method has a single return value.
    auto returnValue = _{{method_name | camelCase}}Handler({%for arg in method.arg_list%}requestArgs.{{arg.name|lowerCamelCase}}{%if not loop.last%}, {%endif%}{%endfor%});
    {{method_name | UpperCamelCase}}ReturnValues returnValues = {returnValue};
    {%else%}
    // Method has multiple return values.
    auto returnValues = _{{method_name | camelCase}}Handler({%for arg in method.arg_list%}requestArgs.{{arg.name|lowerCamelCase}}{%if not loop.last%}, {%endif%}{%endfor%});
    {%endif%}

    if (optResponseTopic)
    {
        rapidjson::Document responseJson;
        responseJson.SetObject();
        
        returnValues.AddToRapidJsonObject(responseJson, responseJson.GetAllocator());

        rapidjson::StringBuffer buf;
        rapidjson::Writer<rapidjson::StringBuffer> writer(buf);
        responseJson.Accept(writer);

        auto msg = stinger::mqtt::Message::MethodResponse(*optResponseTopic, buf.GetString(), optCorrelationData, stinger::error::MethodReturnCode::SUCCESS);
        _broker->Publish(msg);
    }
}
