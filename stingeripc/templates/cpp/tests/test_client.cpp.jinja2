TEST_F({{stinger.cpp.client_class_name}}Test, {{method_name | UpperCamelCase}}PublishesRequest)
{
    _conn->ClearPublishedMessages();

    auto pending = _client->{{method_name | camelCase}}({%for arg in method.arg_list%}{{arg.get_random_example_value(lang="c++")}}{%if not loop.last%}, {%endif%}{%endfor%});

    auto published = _conn->GetPublishedMessages();
    ASSERT_EQ(published.size(), 1u);
    EXPECT_EQ(published[0].topic, stinger::utils::format("{{method.request_topic()}}", topicParams()));

    rapidjson::Document doc;
    EXPECT_FALSE(doc.Parse(published[0].payload.c_str()).HasParseError()) << "Published request payload is not valid JSON";
    EXPECT_TRUE(doc.IsObject());
