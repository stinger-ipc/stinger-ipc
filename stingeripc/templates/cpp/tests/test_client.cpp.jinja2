{
    const std::size_t expected = {{ stinger.signals|length + stinger.methods|length + stinger.properties|length + (1 if stinger.properties|length > 0 else 0) }};
    EXPECT_EQ(_conn->GetSubscriptions().size(), expected);

    {%-for sig_name, sig in stinger.signals.items() %}
    EXPECT_TRUE(_conn->IsSubscribed(stinger::utils::format("{{sig.topic()}}", topicParams()))) << "Not subscribed to {{sig_name}} signal topic";
    {%-endfor%}
    {%-for method_name, method in stinger.methods.items() %}
    EXPECT_TRUE(_conn->IsSubscribed(stinger::utils::format("{{method.response_topic()}}", topicParams()))) << "Not subscribed to {{method_name}} response topic";
    {%-endfor%}
    {%-for prop_name, prop in stinger.properties.items() %}
    EXPECT_TRUE(_conn->IsSubscribed(stinger::utils::format("{{prop.value_topic()}}", topicParams()))) << "Not subscribed to {{prop_name}} property value topic";
